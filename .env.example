SECRET_KEY=your-very-secret-key-change-me
DEBUG=True

# sqlite par défaut | postgres: DB_ENGINE=postgres + docker compose --profile postgres up
DB_ENGINE=sqlite

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=inventory_db
POSTGRES_HOST=inventory_db
POSTGRES_PORT=5432

# Hôtes autorisés (séparés par des virgules). Ajouter le domaine ngrok si besoin.
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines HTTPS autorisées pour le CSRF (login HTML via ngrok, etc.)
# Exemple: CSRF_TRUSTED_ORIGINS=https://xxxx.ngrok.app
CSRF_TRUSTED_ORIGINS=

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Admin
DJANGO_SUPERUSER_PHONE=0000000000
DJANGO_SUPERUSER_IDENTIFICATION_NUMBER=ADMIN0001
